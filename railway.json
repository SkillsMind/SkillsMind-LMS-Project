{
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@railway/node"
    },
    {
      "src": "frontend-new/dist",
      "use": "@railway/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend-new/dist/index.html"
    }
  ]
}